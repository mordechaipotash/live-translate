#!/usr/bin/env bash
# live-translate: Real-time Hebrew → English from Mac microphone
# Pipeline: continuous rec → Whisper (Hebrew STT) → LLM translate → Terminal + JSON + Discord
#
# Parallel record/process — records chunk N+1 while processing chunk N.
# No gaps. 188 lines of bash.
#
# https://github.com/mordechaipotash/live-translate

set -euo pipefail

# --- Config ---
CHUNK_SECS="${CHUNK_SECS:-30}"
DISCORD_CHANNEL=""
WHISPER_CMD="${WHISPER_CMD:-whisper}"
TRANSLATE_MODEL="${TRANSLATE_MODEL:-google/gemini-2.5-flash-lite}"
WORK_DIR="/tmp/live-translate"

# Colors
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
DIM='\033[0;90m'
BOLD='\033[1m'
NC='\033[0m'

# --- Parse args ---
while [[ $# -gt 0 ]]; do
  case $1 in
    --discord) DISCORD_CHANNEL="$2"; shift 2;;
    --chunk) CHUNK_SECS="$2"; shift 2;;
    --help|-h)
      echo "Usage: live-translate [--discord CHANNEL_ID] [--chunk SECONDS]"
      echo ""
      echo "Real-time Hebrew→English translation from your Mac microphone."
      echo ""
      echo "Options:"
      echo "  --discord ID    Discord channel ID for output queue"
      echo "  --chunk SECS    Chunk duration in seconds (default: 30)"
      echo ""
      echo "Environment variables:"
      echo "  OPENROUTER_API_KEY   API key for OpenRouter (required)"
      echo "  WHISPER_CMD          Path to whisper binary (default: whisper)"
      echo "  TRANSLATE_MODEL      OpenRouter model (default: google/gemini-2.5-flash-lite)"
      echo "  CHUNK_SECS           Chunk duration in seconds (default: 30)"
      exit 0
      ;;
    *) echo "Unknown arg: $1"; exit 1;;
  esac
done

# --- Preflight ---
if ! command -v rec &>/dev/null; then
  echo "ERROR: sox/rec not found. Install with: brew install sox"
  exit 1
fi

if ! command -v "$WHISPER_CMD" &>/dev/null && [[ ! -x "$WHISPER_CMD" ]]; then
  echo "ERROR: whisper not found at '$WHISPER_CMD'"
  echo "Install with: pip install openai-whisper"
  echo "Or set WHISPER_CMD to your whisper binary path"
  exit 1
fi

# Load API key from environment or .env files
if [[ -z "${OPENROUTER_API_KEY:-}" ]]; then
  for envfile in "$HOME/.env" ".env"; do
    if [[ -f "$envfile" ]]; then
      export $(grep OPENROUTER_API_KEY "$envfile" 2>/dev/null | xargs) || true
    fi
  done
  if [[ -z "${OPENROUTER_API_KEY:-}" ]]; then
    echo "ERROR: OPENROUTER_API_KEY not set"
    echo "Export it or add to .env file"
    exit 1
  fi
fi

mkdir -p "$WORK_DIR"
echo '[]' > "$WORK_DIR/translations.json"

# --- Functions ---
translate_text() {
  local hebrew_text="$1"
  if [[ ${#hebrew_text} -lt 5 ]]; then return; fi

  local response
  response=$(curl -s --max-time 20 \
    https://openrouter.ai/api/v1/chat/completions \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${OPENROUTER_API_KEY}" \
    -d "$(jq -n \
      --arg text "$hebrew_text" \
      --arg model "$TRANSLATE_MODEL" \
      '{
        model: $model,
        max_tokens: 1024,
        messages: [{
          role: "user",
          content: ("You are translating a live Hebrew tech meetup presentation. Translate the following Hebrew transcription to clear, natural English. This is about AI/ML infrastructure, agents, APIs, Docker, Python, ONNX. Use appropriate tech terminology. Output ONLY the English translation.\n\n" + $text)
        }]
      }')" 2>/dev/null)

  echo "$response" | jq -r '.choices[0].message.content // empty' 2>/dev/null
}

post_to_json() {
  local hebrew="$1" english="$2" timestamp="$3"
  local json_file="$WORK_DIR/translations.json"
  if [[ -f "$json_file" ]]; then
    jq --arg he "$hebrew" --arg en "$english" --arg t "$timestamp" \
      '. += [{"hebrew": $he, "english": $en, "time": $t}]' \
      "$json_file" > "${json_file}.tmp" && mv "${json_file}.tmp" "$json_file"
  fi
}

process_chunk() {
  local chunk_file="$1"
  local chunk_num="$2"

  # Check file size (skip silence)
  local fsize
  fsize=$(stat -f%z "$chunk_file" 2>/dev/null || stat -c%s "$chunk_file" 2>/dev/null || echo "0")
  if [[ "$fsize" -lt 10000 ]]; then
    rm -f "$chunk_file"
    return
  fi

  echo -ne "${DIM}[$(date +%H:%M:%S)] 🔄 Transcribing chunk ${chunk_num}...${NC}\r"

  # Whisper STT (Hebrew)
  "$WHISPER_CMD" "$chunk_file" \
    --language he \
    --model turbo \
    --output_dir "$WORK_DIR" \
    --output_format txt \
    2>/dev/null

  local txt_file="$WORK_DIR/$(basename "${chunk_file%.wav}").txt"
  local hebrew=""
  if [[ -f "$txt_file" ]]; then
    hebrew=$(cat "$txt_file" | tr '\n' ' ' | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
  fi

  # Skip empty, very short, or filler-only chunks
  if [[ -z "$hebrew" || ${#hebrew} -lt 5 ]]; then
    rm -f "$chunk_file" "$txt_file" 2>/dev/null
    return
  fi

  # Skip pure "תודה רבה" chunks (common silence filler)
  if [[ "$hebrew" =~ ^תודה ]]; then
    rm -f "$chunk_file" "$txt_file" 2>/dev/null
    return
  fi

  echo -e "${BLUE}🇮🇱${NC} ${hebrew}"

  # Translate
  local english
  english=$(translate_text "$hebrew")

  if [[ -n "$english" ]]; then
    echo -e "${GREEN}🇬🇧${NC} ${BOLD}${english}${NC}"
    echo ""

    # Append to JSON log
    post_to_json "$hebrew" "$english" "$(date +%H:%M:%S)"

    # Write to Discord queue file
    if [[ -n "$DISCORD_CHANNEL" ]]; then
      echo "🇮🇱 ${hebrew}" >> "$WORK_DIR/discord_queue.txt"
      echo "🇬🇧 ${english}" >> "$WORK_DIR/discord_queue.txt"
      echo "---" >> "$WORK_DIR/discord_queue.txt"
    fi
  fi

  rm -f "$chunk_file" "$txt_file" 2>/dev/null
}

cleanup() {
  echo -e "\n${YELLOW}Stopping...${NC}"
  jobs -p | xargs kill 2>/dev/null || true
  rm -f "$WORK_DIR"/chunk_*.wav 2>/dev/null
  echo -e "${GREEN}Done. Translations saved to $WORK_DIR/translations.json${NC}"
  exit 0
}

trap cleanup SIGINT SIGTERM

# --- Main loop (parallel record + process) ---
echo -e "${BOLD}🎤 Hebrew → English Live Translation${NC}"
echo -e "${DIM}Chunk: ${CHUNK_SECS}s | Model: ${TRANSLATE_MODEL} | Parallel record/process${NC}"
if [[ -n "$DISCORD_CHANNEL" ]]; then
  echo -e "${DIM}Discord queue: ${WORK_DIR}/discord_queue.txt${NC}"
fi
echo -e "${DIM}JSON log: ${WORK_DIR}/translations.json${NC}"
echo -e "${DIM}────────────────────────────────────────${NC}"
echo ""

CHUNK_NUM=0

while true; do
  CHUNK_NUM=$((CHUNK_NUM + 1))
  CHUNK_FILE="$WORK_DIR/chunk_${CHUNK_NUM}.wav"

  # Record chunk
  echo -ne "${DIM}[$(date +%H:%M:%S)] 🔴 Recording chunk ${CHUNK_NUM} (${CHUNK_SECS}s)...${NC}\r"
  rec -q -r 16000 -c 1 -b 16 "$CHUNK_FILE" trim 0 "$CHUNK_SECS" 2>/dev/null

  # Process in background — start recording next chunk immediately (zero gap)
  process_chunk "$CHUNK_FILE" "$CHUNK_NUM" &

  # Small delay to avoid race conditions
  sleep 0.5
done
